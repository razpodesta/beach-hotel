{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "cd ../.. && npx nx build portfolio-web",
  "outputDirectory": "apps/portfolio-web/.next",
  "ignoreCommand": "npx nx affected:apps --plain --base=main --head=HEAD | grep -q portfolio-web || exit 0",
  "cleanUrls": true,
  "trailingSlash": false,
  "regions": ["gru1"],
  "images": {
    "sizes": [256, 384, 640, 750, 828, 1080, 1200, 1920, 2048],
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "flagcdn.com"
      },
      {
        "protocol": "https",
        "hostname": "*.supabase.co"
      }
    ],
    "minimumCacheTTL": 60,
    "formats": ["image/avif", "image/webp"]
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "github": {
    "silent": false,
    "deploymentPreviews": true
  }
}