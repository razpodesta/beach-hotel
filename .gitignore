# --- INFRAESTRUCTRURA CORE ---
node_modules
.next
.nx
dist
coverage
test-output
tmp
.env*
!.env.example

# --- SISTEMA OPERATIVO & IDE ---
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!packages/cms/core/src/payload-types.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- ACTIVOS BINARIOS Y FUENTES ---
# Bloqueamos fuentes por defecto para evitar contaminación de archivos pesados
public/fonts/*

# @fix: EXCEPCIÓN SOBERANA (ADN de Marca)
# Permitimos explícitamente la fuente del logo/firma para evitar el OTS error.
!public/fonts/Dicaten.woff2

# --- PRUEBAS Y CALIDAD (Espejo de Calidad) ---
# @pilar V: No bloqueamos *.spec.ts ni la carpeta /tests.
# Aseguramos que GitHub Actions tenga acceso al ADN de validación.
!tests/
!**/*.spec.ts
!**/*.spec.tsx
!**/*.test.ts
!**/*.test.tsx

# --- INFRAESTRUCTRURA CMS ---
packages/cms/core/src/payload-types.ts
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
