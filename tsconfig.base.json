{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["apps/portfolio-web/src/*"],
      "@portfolio/testing-utils": ["packages/testing-utils/src/index.ts"],
      "@metashark-cms/ui": ["packages/cms/ui/src/index.ts"],
      "@metashark-cms/core": ["packages/cms/core/src/index.ts"],
      "@metashark-cms/core/payload.config": ["packages/cms/core/src/payload.config.ts"],
      "@razpodesta/protocol-33": ["packages/protocol-33/src/index.ts"],
      "@razpodesta/auth-shield": ["packages/auth-shield/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", "**/*.spec.ts", "**/*.test.ts"]
}