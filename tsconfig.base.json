{
  "compileOnSave": false,
  "compilerOptions": {
    /**
     * @pilar XIII: Sincronización de Infraestructura (Vercel & Next.js 15).
     * Silencia la advertencia de 'baseUrl' obsoleta. Se establece en 5.0 para 
     * compatibilidad total con el motor de resolución de Next.js 15.
     */
    "ignoreDeprecations": "5.0",
    
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    
    /**
     * @pilar III: Seguridad de Tipos de Élite.
     * Fuerza el estándar 'import type' para optimizar el Tree-Shaking en producción.
     */
    "verbatimModuleSyntax": true,
    
    "lib": ["esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "incremental": true,

    /* PILAR III: SEGURIDAD DE TIPOS ABSOLUTA - MÁXIMO RIGOR */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* PILAR V: ADHERENCIA ARQUITECTÓNICA (Grafo Soberano) */
    "composite": true,
    "declarationMap": true,

    "baseUrl": ".",
    "paths": {
      /**
       * @description Mapeo de Alias Soberanos. 
       * Permite la resolución "Source-First" eliminando la dependencia de 'dist/'.
       */
      "@/*": ["apps/portfolio-web/src/*"],
      "@metashark/cms-core": ["packages/cms/core/src/index.ts"],
      "@metashark/cms-core/config": ["packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-ui": ["packages/cms/ui/src/index.ts"],
      "@metashark/protocol-33": ["packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["packages/auth-shield/src/index.ts"],
      "@metashark/testing-utils": ["packages/testing-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}