{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    
    /**
     * @pilar III: Seguridad de Tipos.
     * Activamos verbatimModuleSyntax para forzar 'import type' y mejorar el Tree-Shaking.
     */
    "verbatimModuleSyntax": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "incremental": true,

    /**
     * @fix: Corrección TS6305
     * Silencia la advertencia de deprecación de baseUrl sin perder funcionalidad.
     */
    "ignoreDeprecations": "5.0",

    /* PILAR III: SEGURIDAD DE TIPOS ABSOLUTA */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* PILAR V: ADHERENCIA ARQUITECTÓNICA */
    "composite": true,
    "declarationMap": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/portfolio-web/src/*"],
      "@metashark/cms-core": ["packages/cms/core/src/index.ts"],
      "@metashark/cms-core/config": ["packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-ui": ["packages/cms/ui/src/index.ts"],
      "@metashark/protocol-33": ["packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["packages/auth-shield/src/index.ts"],
      "@metashark/testing-utils": ["packages/testing-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}