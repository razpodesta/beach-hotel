{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "importHelpers": true,
    "noPropertyAccessFromIndexSignature": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      /* 
         @pilar V: Alias estrictos. 
         Centralización absoluta para evitar colisiones de empaquetado.
      */
      "@/*": ["apps/portfolio-web/src/*"],
      "@metashark/cms-core/config": ["packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-core": ["packages/cms/core/src/index.ts"],
      "@metashark/cms-ui": ["packages/cms/ui/src/index.ts"],
      "@metashark/protocol-33": ["packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["packages/auth-shield/src/index.ts"],
      "@metashark/testing-utils": ["packages/testing-utils/src/index.ts"]
    }
  },
  "exclude": [
    "node_modules", 
    "tmp", 
    "dist", 
    "**/*.spec.ts", 
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx"
  ]
}