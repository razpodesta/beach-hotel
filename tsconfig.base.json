{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "importHelpers": true,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      /* 
         Mapeos Específicos (Prioridad Alta) 
         @pilar V: Se colocan primero para evitar colisiones con comodines.
      */
      "@metashark/cms-core/config": ["packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-core/collections": ["packages/cms/core/src/collections/index.ts"],
      
      /* 
         Mapeos de Paquetes (Entry Points) 
      */
      "@metashark/cms-core": ["packages/cms/core/src/index.ts"],
      "@metashark/cms-ui": ["packages/cms/ui/src/index.ts"],
      "@metashark/protocol-33": ["packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["packages/auth-shield/src/index.ts"],
      "@metashark/testing-utils": ["packages/testing-utils/src/index.ts"],

      /* 
         Mapeos Generales (Catch-all)
      */
      "@metashark/cms-core/*": ["packages/cms/core/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}