{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "sourceMap": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "incremental": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/portfolio-web/src/*"],
      "@metashark/cms-core": ["packages/cms/core/src/index.ts"],
      "@metashark/cms-core/config": ["packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-ui": ["packages/cms/ui/src/index.ts"],
      "@metashark/protocol-33": ["packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["packages/auth-shield/src/index.ts"],
      "@metashark/identity-gateway": ["packages/identity-gateway/src/index.ts"],
      "@metashark/testing-utils": ["packages/testing-utils/src/index.ts"],
      "@metashark/communication-dispatch-hub": [
        "packages/communication-dispatch-hub/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", ".nx"]
}
