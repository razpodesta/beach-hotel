/**
 * @file tsconfig.spec.json (Root)
 * @description Orquestador de Tipos para la Infraestructura de Calidad y Scripts.
 *              Versión 9.0 - Build Isolation & Conflict Resolution.
 * 
 * @pilar V: Adherencia Arquitectónica - Sincronía con la red de 12 nodos @metashark.
 * @pilar XIII: Soberanía de Artefactos - Aislamiento de metadatos de validación.
 */
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* --- 1. ENTORNO DE EJECUCIÓN (JEST/NODE) --- */
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "types": ["jest", "node", "react", "react-dom"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "jsx": "react-jsx",

    /* --- 2. GOBERNANZA DE EMISIÓN (Pilar XIII) --- */
    /**
     * @fix: Resolución de conflicto estructural.
     * Desactivamos 'composite' en este nodo de utilidad para permitir 'noEmit: true'
     * y evitar la generación de basura técnica en el directorio raíz.
     */
    "composite": false,
    "noEmit": true,
    "incremental": true,
    
    /**
     * @description Redirección de telemetría de compilación a la zona industrial.
     */
    "tsBuildInfoFile": "./dist/out-tsc/root-tests.tsbuildinfo",
    
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  
  /* --- 3. PERÍMETRO DE COBERTURA --- */
  "include": [
    "jest.config.ts",
    "jest.preset.js",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    /**
     * @description Visibilidad sobre los contratos de los Silos para 
     * validación cruzada en el motor de pruebas.
     */
    "packages/**/src/**/*.ts",
    "packages/**/src/**/*.tsx"
  ],

  "exclude": [
    "node_modules", 
    "dist",
    "apps/portfolio-web/.next"
  ]
}