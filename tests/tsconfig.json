/**
 * @file tests/tsconfig.json
 * @description Configuración soberana del Espejo de Calidad.
 *              Nivelado: Transición a ESM ('esnext' / 'bundler') para erradicar 
 *              el error TS1295 bajo 'verbatimModuleSyntax'. La transpilación
 *              JIT en tiempo de ejecución se delega exclusivamente a @swc/jest.
 * @version 12.0 - ESM Sync & TS1295 Resolution
 * @author Raz Podestá - MetaShark Tech
 */
{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    /* 
       PILAR V: ADHERENCIA ARQUITECTÓNICA
       Mantenemos composite para permitir la orquestación desde la raíz.
    */
    "composite": true,
    
    /* 
       RESOLUCIÓN ESM SOBERANA:
       Evita el bloqueo TS1295 al permitir sintaxis import/export nativa.
       Alineado con el estándar del ecosistema MetaShark.
    */
    "module": "esnext",
    "moduleResolution": "bundler",
    
    /* 
       PILAR XIII: PUREZA DE SOURCE
       Bloqueamos la emisión física para evitar la creación de artefactos
       redundantes en el directorio de pruebas.
    */
    "noEmit": true,
    "types":[
      "node", 
      "jest", 
      "@testing-library/jest-dom", 
      "react", 
      "react-dom"
    ],
    "jsx": "react-jsx"
  },
  "include":[
    "**/*.ts", 
    "**/*.tsx",
    "../apps/portfolio-web/jest.setup.ts",
    "../tests/jest.config.ts"
  ]
}