/**
 * @file tests/tsconfig.json
 * @description Configuración soberana del Espejo de Calidad.
 *              Implementa validación cruzada mediante Project References.
 */
{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    /* 
       PILAR V: ADHERENCIA ARQUITECTÓNICA
       Activamos 'composite' para que este proyecto pueda ser parte 
       del grafo referenciado desde la raíz.
    */
    "composite": true,
    
    /* 
       MODO SOURCE-FIRST:
       Los tests consumen código fuente. Usamos 'commonjs' y 'node' 
       porque Jest (nuestro motor de tests) corre en Node.js puro.
    */
    "module": "commonjs",
    "moduleResolution": "node",
    "emitDeclarationOnly": false,
    "noEmit": true,

    /* Tipado específico para el entorno de pruebas */
    "types": [
      "node", 
      "jest", 
      "@testing-library/jest-dom", 
      "react", 
      "react-dom"
    ],
    "jsx": "react-jsx"
  },
  "include": [
    "**/*.ts", 
    "**/*.tsx",
    "../apps/portfolio-web/jest.setup.ts" // Inyectamos el setup de la app
  ],
  /* 
     EL PUENTE FÍSICO:
     Referenciamos todos los proyectos que estos tests van a auditar.
     Esto garantiza que los tipos de las librerías estén actualizados.
  */
  "references": [
    { "path": "../apps/portfolio-web" },
    { "path": "../packages/cms/core" },
    { "path": "../packages/cms/ui" },
    { "path": "../packages/testing-utils" },
    { "path": "../packages/protocol-33" },
    { "path": "../packages/auth-shield" }
  ]
}