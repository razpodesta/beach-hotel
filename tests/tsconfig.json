{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../apps/portfolio-web/src/*"],
      "@metashark/cms-core/*": ["../packages/cms/core/src/*"],
      "@portfolio/testing-utils": ["../packages/testing-utils/src/index.ts"]
    },
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": ["node", "jest", "@testing-library/jest-dom", "react", "react-dom"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "references": [
    {
      "path": "../packages/cms/core"
    }
  ]
}
