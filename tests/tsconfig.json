{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "../dist/out-tsc/tests/tsconfig.tsbuildinfo",
    "outDir": "../dist/out-tsc/tests",
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "rootDir": ".",
    "types": [
      "node", 
      "jest", 
      "@testing-library/jest-dom", 
      "react", 
      "react-dom"
    ],
    "jsx": "react-jsx"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "../dist",
    "../apps/portfolio-web/jest.setup.ts"
  ]
}