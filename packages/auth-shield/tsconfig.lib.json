{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* SOBERANÍA DE SALIDA: Alineado con la raíz del monorepo */
    "outDir": "../../dist/packages/auth-shield",
    
    /* 
       ESCUDO ANTI-6305: 
       Poda el árbol de directorios para que el dist sea plano.
    */
    "rootDir": "src",
    
    /* PILAR V: COMPOSITE SYNC */
    "composite": true,
    "emitDeclarationOnly": false, 
    "tsBuildInfoFile": "../../dist/packages/auth-shield/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}