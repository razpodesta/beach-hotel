/**
 * @file packages/identity-access-management/tsconfig.lib.json
 * @description Configuración de validación para la librería IAM.
 *              Nivelado: Resolución de rutas de salida y soporte para diccionarios.
 * @version 2.1 - Build Path Re-mapped
 * @author Staff Engineer - MetaShark Tech
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /**
     * @description Redireccionamos la salida técnica al perímetro correcto en /dist.
     */
    "outDir": "../../dist/packages/identity-access-management",
    "rootDir": "src",
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "tsBuildInfoFile": "../../dist/packages/identity-access-management/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "src/**/*.json"
  ],
  "exclude": [
    "**/*.spec.ts", 
    "**/*.test.ts", 
    "**/*.spec.tsx", 
    "**/*.test.tsx",
    "node_modules",
    "dist"
  ]
}