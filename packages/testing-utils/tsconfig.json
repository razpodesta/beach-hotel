{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types":["node", "jest", "react", "react-dom"]
  },
  "include":["src/**/*.ts", "src/**/*.tsx"],
  "exclude":[
    "node_modules",
    "dist",
    "jest.config.ts",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references":[
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}