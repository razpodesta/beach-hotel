{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    
    /* 
       PILAR V: ADHERENCIA AL GRAFO 
       'composite' permite que este proyecto sea referenciado 
       por la raíz y por la suite de /tests.
    */
    "composite": true,
    "rootDir": ".",
    
    /* 
       PILAR XIII: PUREZA DE SOURCE
       Bloquea la emisión física en el entorno IDE. La generación de los 
       artefactos de infraestructura de pruebas se delega a tsconfig.lib.json.
    */
    "noEmit": true,
    
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    
    "declaration": true,
    "declarationMap": true,

    /* Tipado híbrido para el ecosistema de pruebas (DOM + Node) */
    "types":["node", "jest", "react", "react-dom"]
  },
  "include":[
    "src/**/*.ts", 
    "src/**/*.tsx"
  ],
  "exclude":[
    "node_modules", 
    "dist", 
    "jest.config.ts", 
    "src/**/*.spec.ts"
  ],
  "references":[
    { "path": "./tsconfig.lib.json" }
  ]
}