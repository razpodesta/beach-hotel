{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    /* 
       PILAR V: ADHERENCIA AL GRAFO 
       'composite' permite que este proyecto sea referenciado por el root y por /tests.
    */
    "composite": true,
    "rootDir": ".",
    
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    
    "declaration": true,
    "declarationMap": true,

    /* Tipado para el ecosistema de pruebas */
    "types": ["node", "jest", "react", "react-dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "jest.config.ts", "src/**/*.spec.ts"],
  "references": [
    { "path": "./tsconfig.lib.json" }
  ]
}