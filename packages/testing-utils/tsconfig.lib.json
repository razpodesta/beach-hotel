{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/packages/testing-utils",
    "rootDir": "src",
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "tsBuildInfoFile": "../../dist/packages/testing-utils/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}