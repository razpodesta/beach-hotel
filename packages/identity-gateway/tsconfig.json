/**
 * @file packages/identity-gateway/tsconfig.json
 * @description Configuración Soberana de TypeScript para la Pasarela de Identidad.
 *              Refactorizado: Resolución de typos de compilador y alineación 
 *              con el estándar de depreciaciones TS 5.x/6.x.
 * @version 1.1 - Syntax & Standard Hardened
 * @author Staff Engineer - MetaShark Tech
 */
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /**
     * @pilar XIII: Sincronización de Infraestructura.
     * Elevamos a '6.0' para silenciar advertencias de baseUrl en 
     * configuraciones que heredan de bases complejas.
     */
    "ignoreDeprecations": "5.0",
    
    /* PILAR V: ADHERENCIA ARQUITECTÓNICA (Grafo Soberano) */
    "composite": true,
    "incremental": true,
    
    /**
     * @pilar XIII: Soberanía de Artefactos.
     * Aislamiento físico de metadatos para evitar colisiones 
     * durante la síntesis del monorepo.
     */
    "tsBuildInfoFile": "../../dist/packages/identity-gateway/tsconfig.tsbuildinfo",
    
    /**
     * PILAR IX: DELEGACIÓN DE COMPILACIÓN (Dual-Mode)
     * Generamos solo declaraciones (.d.ts) para que Next.js consuma el 
     * contrato mientras SWC procesa el fuente (.ts).
     */
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,

    "baseUrl": ".",
    "rootDir": "src",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node", "react", "react-dom"],

    /* 
       REVISIÓN DE RIGOR: 
       Corrección de typo 'noFallthroughCases_in_switch' -> 'noFallthroughCasesInSwitch'
    */
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules", 
    "dist", 
    "jest.config.ts", 
    "**/*.spec.ts", 
    "**/*.spec.tsx"
  ]
}