{
  "name": "@metashark/identity-gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/identity-gateway/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:ui", "layer:security"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/identity-gateway/tsconfig.lib.json --noEmit",
        "forwardAllArgs": true
      },
      "dependsOn":["^typecheck"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/test-output/jest/coverage/packages/identity-gateway"],
      "options": {
        "jestConfig": "packages/identity-gateway/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}