{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "rootDir": ".",
    
    /* 
       RESOLUCIÓN ISOMÓRFICA:
       Usamos 'bundler' para que el VisitorHud (Next.js) consuma 
       la lógica de XP con la máxima agilidad.
    */
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    
    "declaration": true,
    "declarationMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "jest.config.ts", "**/*.spec.ts"],
  "references": [
    { "path": "./tsconfig.lib.json" }
  ]
}