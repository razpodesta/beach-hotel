/**
 * @file packages/protocol-33/tsconfig.json
 * @description Configuración base del motor de reputación.
 *              Refactorizado: Resolución de TS 'cannot disable emission'
 *              permitiendo la generación de declaraciones para consumidores.
 * @version 2.1 - Project Reference Enabled
 */
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /** @fix Sincronización de infraestructura TS 5.x */
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "composite": true,
    "rootDir": ".",
    
    /** 
     * @fix: Cambio de noEmit a false para permitir referencias de proyecto.
     * Activamos 'emitDeclarationOnly' para que el IDE genere los tipos
     * necesarios para el CMS sin ensuciar con archivos .js el source.
     */
    "noEmit": false,
    "emitDeclarationOnly": true,
    
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules", 
    "dist", 
    "jest.config.ts", 
    "**/*.spec.ts"
  ]
}