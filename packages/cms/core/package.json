{
  "name": "@metashark/cms-core",
  "version": "0.0.1",

  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },

    "./config": {
      "types": "./src/payload.config.ts",
      "import": "./src/payload.config.ts",
      "default": "./dist/payload.config.js"
    },
    "./collections": {
      "types": "./src/collections/index.ts",
      "import": "./src/collections/index.ts",
      "default": "./dist/collections/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "tslib": "^2.3.0"
  }
}