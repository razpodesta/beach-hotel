{
  "name": "@metashark/cms-core",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cms/core/src",
  "projectType": "library",
  "tags": ["scope:cms", "type:core", "layer:data"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/cms/core",
        "main": "packages/cms/core/src/index.ts",
        "tsConfig": "packages/cms/core/tsconfig.lib.json",
        /**
         * @pilar XIII: Alineación con el Motor.
         * Emisión exclusiva en ESM para erradicar ruidos de construcción en Vercel.
         */
        "format": ["esm"],
        "assets": [
          "packages/cms/core/*.md",
          {
            "input": "packages/cms/core/src",
            "glob": "**/*.!(ts|tsx)",
            "output": "./"
          }
        ],
        /**
         * @pilar VIII: Resiliencia de Dependencias.
         * Genera un bundle de producción autónomo con sus propias definiciones de módulos.
         */
        "generatePackageJson": true,
        "updateBuildableProjectDepsInPackageJson": true,
        "clean": true
      },
      "description": "Compilación soberana del núcleo de datos MetaShark."
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/cms/core/tsconfig.lib.json --noEmit",
        "forwardAllArgs": true
      },
      /**
       * @pilar X: Performance - Definición de inputs para habilitar el caché de Nx.
       * Esto evita validaciones redundantes en el pipeline de Vercel.
       */
      "inputs": ["production", "^production"],
      "dependsOn": ["^build"],
      "description": "Verificación forense de integridad de tipos del CMS."
    },
    "lint": { 
      "executor": "@nx/eslint:lint",
      "inputs": ["default", "{workspaceRoot}/eslint.config.mjs"],
      "description": "Auditoría estática de calidad y fronteras de módulo."
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/packages/cms/core"],
      "options": {
        "jestConfig": "packages/cms/core/jest.config.ts",
        "passWithNoTests": true
      },
      "description": "Ejecución de validaciones de lógica en el Espejo de Calidad."
    }
  }
}