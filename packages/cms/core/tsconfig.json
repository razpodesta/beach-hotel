/**
 * @file packages/cms/core/tsconfig.json
 * @description Orquestador soberano de tipos para el Núcleo CMS (DX Mode).
 *              Refactorizado: Mitigación de advertencia de obsolescencia 'baseUrl'
 *              mediante ignoreDeprecations flag, alineado con TS 5.0+.
 * @version 7.1 - TS Deprecation Mitigation Sync
 * @author Raz Podestá - MetaShark Tech
 */
{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    /**
     * @pilar XIII: Sincronización de Infraestructura.
     * Silencia la advertencia de baseUrl obsoleta para mantener un log de build prístino.
     */
    "ignoreDeprecations": "5.0",
    
    "baseUrl": ".",
    /** 
     * PILAR V: ADHERENCIA AL GRAFO SOBERANO
     * Mantenemos 'composite' para que la raíz reconozca este dominio,
     * pero sin referencias locales para evitar el bloqueo TS6305.
     */
    "composite": true,
    "rootDir": ".",
    
    /** 
     * PILAR XIII: PUREZA DE SOURCE (Blindaje Total)
     * Se bloquea la emisión física en el entorno de desarrollo para evitar 
     * contaminar 'src/' con basura compilada.
     */
    "noEmit": true,

    /** 
     * RESOLUCIÓN HÍBRIDA (DX Mode):
     * @fix Resolución del conflicto de extensiones. Cambiamos 'nodenext' por 
     * 'bundler' para permitir importaciones sin extensión en el IDE, 
     * alineándonos con el motor SWC de Next.js 15.
     */
    "module": "esnext",
    "moduleResolution": "bundler",

    /**
     * @pilar III: Seguridad de Tipos Absoluta.
     * Fuerza el estándar 'import type' para evitar fugas de código en producción.
     */
    "verbatimModuleSyntax": true,

    /**
     * @pilar VIII: Resiliencia de Transpilación.
     */
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    
    "declaration": true,
    "declarationMap": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    /** 
     * @pilar I: Visión Holística.
     * Sincronía total con el contrato generado por Payload.
     */
    "src/payload-types.ts"
  ],
  "exclude": [
    "node_modules", 
    "dist", 
    "jest.config.ts", 
    "src/**/*.spec.ts"
  ]
}