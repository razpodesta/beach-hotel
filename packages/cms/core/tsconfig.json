/**
 * @file packages/cms/core/tsconfig.json
 * @description Orquestador soberano de tipos para el Núcleo CMS (DX Mode).
 *              Implementa arquitectura Source-First, resolución ESM estricta 
 *              y blindaje de emisión para garantizar la pureza del directorio src/.
 * @version 6.0 - Verbatim Syntax & Dual-Mode Alignment
 * @author Raz Podestá - MetaShark Tech
 */
{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    /** 
     * PILAR V: ADHERENCIA AL GRAFO SOBERANO
     * 'composite' permite que el proyecto sea referenciado por la raíz del monorepo,
     * habilitando Intellisense transversal sin necesidad de compilación previa.
     */
    "composite": true,
    "rootDir": ".",
    
    /** 
     * PILAR XIII: PUREZA DE SOURCE (Blindaje Total)
     * Se bloquea la emisión física para evitar la generación de archivos .js/.d.ts 
     * que contaminen la carpeta de código fuente. La emisión se delega a tsconfig.lib.json.
     */
    "noEmit": true,

    /** 
     * RESOLUCIÓN DE CORE (Strict ESM):
     * @pilar XIII: Alineación con el Motor.
     * 'nodenext' fuerza el cumplimiento de ESM en el IDE, asegurando paridad
     * con los scripts de infraestructura y el runtime de Next.js 15.
     */
    "module": "nodenext",
    "moduleResolution": "nodenext",

    /**
     * @pilar III: Seguridad de Tipos Absoluta.
     * 'verbatimModuleSyntax' obliga al uso explícito de 'import type'.
     * Crucial para evitar que el compilador emita JS con referencias a tipos 
     * que no existen en el bundle de ejecución de Vercel.
     */
    "verbatimModuleSyntax": true,

    /**
     * @pilar VIII: Resiliencia de Transpilación.
     * Garantiza que cada archivo pueda ser transpilado de forma independiente por SWC.
     */
    "isolatedModules": true,
    
    "declaration": true,
    "declarationMap": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    /** 
     * @pilar I: Visión Holística.
     * Inclusión del contrato generado por Payload para sincronía total de tipos.
     */
    "src/payload-types.ts"
  ],
  "exclude": [
    "node_modules", 
    "dist", 
    "jest.config.ts", 
    "src/**/*.spec.ts"
  ]
  /** 
   * ELIMINACIÓN ESTRATÉGICA: Array 'references' eliminado.
   * Se rompe la cadena de dependencia circular local para permitir 'noEmit: true'
   * bajo el estándar de 'composite', erradicando el error TS6305.
   */
}