/**
 * @file packages/cms/core/tsconfig.lib.json
 * @description Generador de Metadatos de Tipos.
 *              Nx usa este archivo SOLO para extraer los .d.ts al hacer build.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/packages/cms/core",
    "rootDir": "src",
    "composite": false,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*.ts", "payload-types.ts"],
  "exclude": ["jest.config.ts", "**/*.spec.ts", "**/*.test.ts"]
}