{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/packages/cms/core",
    "rootDir": "src",
    
    /* 
       RESOLUCIÓN NATIVA ALINEADA:
       El uso de 'bundler' permite importaciones limpias sin extensiones .js,
       garantizando que el IDE, Nx (vía tsx) y Next.js (vía SWC/Vercel) 
       interpreten y compilen el código sin colisiones.
    */
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "composite": true,
    
    "noEmit": false,
    "emitDeclarationOnly": false, 
    "tsBuildInfoFile": "../../../dist/packages/cms/core/tsconfig.lib.tsbuildinfo"
  },
  "include":[
    "src/**/*.ts",
    "src/payload-types.ts"
  ],
  "exclude":[
    "**/*.spec.ts", 
    "**/*.test.ts"
  ]
}