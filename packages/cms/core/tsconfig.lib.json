{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* SOBERANÍA DE SALIDA: Directorio de distribución global */
    "outDir": "../../../dist/packages/cms/core",
    
    /* 
       PROFILAXIS TS6305: 
       Al fijar rootDir en 'src', evitamos que la carpeta 'dist' contenga 
       subcarpetas 'packages/cms/core/src'. El resultado será un dist limpio.
    */
    "rootDir": "src",
    
    "composite": true,
    "emitDeclarationOnly": false, 
    "tsBuildInfoFile": "../../../dist/packages/cms/core/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/payload-types.ts"
  ],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}