{
  "name": "@metashark/cms-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cms/ui/src",
  "projectType": "library",
  "tags": ["scope:cms", "type:ui", "layer:presentation"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/cms/ui",
        "main": "packages/cms/ui/src/index.ts",
        "tsConfig": "packages/cms/ui/tsconfig.lib.json",
        "assets": [
          "packages/cms/ui/*.md",
          {
            "input": "packages/cms/ui/src",
            "glob": "**/*.css",
            "output": "./"
          }
        ],
        "clean": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/cms/ui/tsconfig.lib.json --noEmit",
        "forwardAllArgs": true
      },
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/packages/cms/ui"],
      "options": {
        "jestConfig": "packages/cms/ui/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}