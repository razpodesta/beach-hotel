{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "outDir": "../../../dist/packages/cms/ui",
    "emitDeclarationOnly": false,
    "tsBuildInfoFile": "../../../dist/packages/cms/ui/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "src/**/*.d.ts"
  ],
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx"
  ]
}