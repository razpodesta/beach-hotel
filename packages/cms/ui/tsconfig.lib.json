{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* SOBERANÍA DE SALIDA: Directorio de distribución global */
    "outDir": "../../../dist/packages/cms/ui",
    
    /* 
       PROFILAXIS TS6305: 
       Al fijar rootDir en 'src', garantizamos que los componentes se compilen 
       en la raíz del dist, evitando anidamientos redundantes.
    */
    "rootDir": "src",
    
    "composite": true,

    /* 
       PILAR XIII: FORZADO DE EMISIÓN (Override)
       Anula el "noEmit": true del archivo padre (tsconfig.json) para permitir
       que el compilador de Nx genere los artefactos físicos (.js y .d.ts) 
       requeridos por el pipeline de Vercel.
    */
    "noEmit": false,
    "emitDeclarationOnly": false, 
    
    "tsBuildInfoFile": "../../../dist/packages/cms/ui/tsconfig.lib.tsbuildinfo"
  },
  "include":[
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "src/global.d.ts"
  ],
  "exclude":[
    "**/*.spec.ts", 
    "**/*.test.ts", 
    "**/*.spec.tsx", 
    "**/*.test.tsx"
  ]
}