{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* SOBERANÍA DE SALIDA: Directorio global dist */
    "outDir": "../../../dist/packages/cms/ui",
    
    /* 
       PROFILAXIS TS6305: 
       Al fijar rootDir en 'src', garantizamos que los componentes se compilen 
       en la raíz del dist, evitando anidamientos redundantes.
    */
    "rootDir": "src",
    
    "composite": true,
    "emitDeclarationOnly": false, 
    "tsBuildInfoFile": "../../../dist/packages/cms/ui/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/global.d.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "**/*.spec.tsx", "**/*.test.tsx"]
}