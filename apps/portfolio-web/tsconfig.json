{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    /* 
       PILAR V: ADHERENCIA AL GRAFO SOBERANO
       'composite' es obligatorio para que el proyecto 'tests' 
       pueda referenciar la lógica de las páginas.
    */
    "composite": true,
    
    /* 
       PILAR XIII: PUREZA DE SOURCE (Mata el conflicto noEmit)
       Next.js usualmente pide noEmit: true. Aquí usamos emitDeclarationOnly
       hacia el dist para satisfacer a TypeScript sin ensuciar el source.
    */
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "../../dist/apps/portfolio-web/types",

    /* CONFIGURACIÓN NEXT.JS 15 + REACT 19 */
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "incremental": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts", 
    ".next/types/**/*.ts",
    "src/**/*.ts", 
    "src/**/*.tsx"
  ],
  "exclude": ["node_modules", ".next", "dist"],
  /* 
     MAPA DE SUMINISTROS (Project References):
     Permite que el IDE "salte" al código fuente de las librerías 
     con un solo click y valida tipos en tiempo real.
  */
  "references": [
    { "path": "../../packages/cms/core" },
    { "path": "../../packages/cms/ui" },
    { "path": "../../packages/protocol-33" },
    { "path": "../../packages/auth-shield" }
  ]
}