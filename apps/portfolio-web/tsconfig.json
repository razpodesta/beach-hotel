{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "../../dist/apps/portfolio-web/tsconfig.tsbuildinfo",
    "noEmit": true,
    "jsx": "preserve",
    "plugins": [
      { "name": "next" }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@payloadcms/next/importMap": ["./.next/types/payload-import-map.js"],
      "@payloadcms/next/views/*": ["../../node_modules/@payloadcms/next/dist/views/*"]
    }
  },
  "include": [
    "next-env.d.ts", 
    ".next/types/**/*.ts",
    "src/**/*.ts", 
    "src/**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ],
  "exclude": [
    "node_modules", 
    "dist", 
    "../../dist", 
    ".next", 
    "out", 
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}