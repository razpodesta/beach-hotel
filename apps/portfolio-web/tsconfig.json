{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* 
       PILAR XIII: Sincronización con Vercel/Next.js 15
       'ignoreDeprecations' debe ser "6.0" para silenciar el aviso de baseUrl.
    */
    "ignoreDeprecations": "6.0",
    
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "../../dist/apps/portfolio-web/tsconfig.tsbuildinfo",
    
    "noEmit": true,

    /* 
       CONFIGURACIÓN ESPECÍFICA DE NEXT.JS 
       Mantenemos solo las que no están en el base para evitar duplicidad.
    */
    "jsx": "preserve",
    "plugins": [
      { "name": "next" }
    ]
  },
  "include": [
    "next-env.d.ts", 
    ".next/types/**/*.ts",
    "src/**/*.ts", 
    "src/**/*.tsx",
    "../../packages/**/src/**/*.ts",
    "../../packages/**/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "../../dist",
    ".next",
    "out"
  ]
}