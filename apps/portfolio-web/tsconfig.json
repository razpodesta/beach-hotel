{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "plugins": [{ "name": "next" }],
    /* 
       @pilar V: Restauración de Alias Soberanos.
       Debido a que TS no combina 'paths', debemos incluir tanto los alias 
       locales como los del monorepo para asegurar la resolución.
    */
    "paths": {
      "@/*": ["./src/*"],
      "@metashark/cms-core/config": ["../../packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-core/collections": ["../../packages/cms/core/src/collections/index.ts"],
      "@metashark/cms-core": ["../../packages/cms/core/src/index.ts"],
      "@metashark/cms-ui": ["../../packages/cms/ui/src/index.ts"],
      "@metashark/protocol-33": ["../../packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["../../packages/auth-shield/src/index.ts"],
      "@metashark/testing-utils": ["../../packages/testing-utils/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts", 
    ".next/types/**/*.ts",
    "**/*.ts", 
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "jest.config.ts",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    { "path": "../../packages/protocol-33" },
    { "path": "../../packages/auth-shield" },
    { "path": "../../packages/cms/ui" },
    { "path": "../../packages/cms/core" },
    { "path": "../../packages/testing-utils" }
  ]
}