{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    
    /* 
       PILAR V: ADHERENCIA AL GRAFO SOBERANO
       'composite' requiere 'incremental' activo en TS.
    */
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "../../dist/apps/portfolio-web/tsconfig.tsbuildinfo",
    
    /* 
       PILAR XIII: ALINEACIÓN CON EL MOTOR NEXT.JS
    */
    "noEmit": true,

    /* CONFIGURACIÓN NEXT.JS 15 + REACT 19 */
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts", 
    ".next/types/**/*.ts",
    "src/**/*.ts", 
    "src/**/*.tsx",
    "../../packages/**/src/**/*.ts",
    "../../packages/**/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "../../dist",
    ".next"
  ]
}