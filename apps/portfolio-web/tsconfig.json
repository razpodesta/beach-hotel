/**
 * @file apps/portfolio-web/tsconfig.json
 * @description Orquestador de Tipos de la App Web (Oxygen Shell).
 *              Refactorizado: Consolidación de alias (Paths Merge) para restaurar 
 *              la visibilidad de @metashark/* tras la colisión de herencia.
 *              Nivelado: Inclusión profunda de fuentes para paquetes anidados.
 * @version 7.2 - Path Consolidation & Deep Source Visibility
 * @author Staff Engineer - MetaShark Tech
 */
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /**
     * @pilar XIII: Sincronización de Infraestructura.
     */
    "ignoreDeprecations": "5.0",

    /**
     * @pilar IX: Delegación de Compilación (Pure Source-First).
     */
    "composite": false,
    "incremental": true,
    "noEmit": true,

    /**
     * @pilar XIII: Soberanía de Artefactos.
     */
    "tsBuildInfoFile": "../../dist/apps/portfolio-web/tsconfig.tsbuildinfo",

    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,

    "plugins": [
      {
        "name": "next"
      }
    ],

    /**
     * @fix: Fusión de Caminos (Path Consolidation).
     * @description Se restauran los alias de la base ya que TS no los hereda 
     *              si se define un bloque 'paths' local.
     */
    "paths": {
      "@/*": ["./src/*"],
      
      // Mapeos dinámicos de Payload 3.0
      "@payloadcms/next/importMap": ["./.next/types/payload-import-map.js"],
      "@payloadcms/next/views/*": ["../../node_modules/@payloadcms/next/dist/views/*"],

      // Mapeos del Monorepo (Restaurados)
      "@metashark/cms-core": ["../../packages/cms/core/src/index.ts"],
      "@metashark/cms-core/config": ["../../packages/cms/core/src/payload.config.ts"],
      "@metashark/cms-ui": ["../../packages/cms/ui/src/index.ts"],
      "@metashark/reputation-engine": ["../../packages/protocol-33/src/index.ts"],
      "@metashark/auth-shield": ["../../packages/auth-shield/src/index.ts"],
      "@metashark/identity-gateway": ["../../packages/identity-gateway/src/index.ts"],
      "@metashark/testing-utils": ["../../packages/testing-utils/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "payload-types.d.ts",
    
    /**
     * @pilar IV: Pure Source-First (Visibilidad de Librerías).
     * @description Globbing profundo (**) para capturar paquetes en subcarpetas 
     *              como 'packages/cms/core' y 'packages/identity-gateway'.
     */
    "../../packages/**/src/**/*.ts",
    "../../packages/**/src/**/*.tsx",
    "../../packages/**/src/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "out",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}