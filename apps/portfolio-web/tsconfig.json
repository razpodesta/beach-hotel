{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    
    /**
     * @pilar_V: Adherencia al Grafo Soberano.
     * 'composite' requiere que todas las dependencias externas 
     * sean rastreables mediante 'references'.
     */
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "../../dist/apps/portfolio-web/tsconfig.tsbuildinfo",
    
    /**
     * @pilar_XIII: Alineación con el Motor Next.js.
     */
    "noEmit": true,

    /* CONFIGURACIÓN NEXT.JS 15 + REACT 19 STANDARDS */
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts", 
    ".next/types/**/*.ts",
    "src/**/*.ts", 
    "src/**/*.tsx",
    /**
     * @fix_TS6307: Globbing recursivo. 
     * El uso de '**' permite alcanzar subcarpetas como 'packages/cms/core'.
     */
    "../../packages/**/src/**/*.ts",
    "../../packages/**/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "../../dist",
    ".next",
    "out"
  ]
}