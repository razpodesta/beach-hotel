{
  "name": "@metashark/portfolio-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/portfolio-web/src",
  "projectType": "application",
  "tags": ["platform:web", "scope:metashark", "type:app"],
  "targets": {
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/prebuild-portfolio-web.ts",
        "color": true
      },
      "inputs": ["{projectRoot}/src/messages/**/*.json"],
      "outputs": ["{projectRoot}/src/dictionaries/*.json"],
      "description": "Protocolo MACS: Ensamblaje y validación soberana de diccionarios i18n."
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}",
        "{workspaceRoot}/dist/apps/portfolio-web/.next",
        "{workspaceRoot}/dist/apps/portfolio-web/public"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/portfolio-web"
      },
      "dependsOn": [
        "^build",
        "prebuild"
      ],
      "configurations": {
        "production": {
          "debug": false,
          "generateSourcemaps": false
        }
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "options": {
        "buildTarget": "@metashark/portfolio-web:build",
        "dev": true,
        "port": 4200
      },
      "dependsOn": ["prebuild"],
      "configurations": {
        "production": {
          "buildTarget": "@metashark/portfolio-web:build:production",
          "dev": false
        }
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/portfolio-web/tsconfig.json --noEmit",
        "forwardAllArgs": true
      },
      "cache": true,
      "dependsOn": ["^build"],
      "description": "Verificación estática de tipos de élite sobre el código fuente."
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/portfolio-web"],
      "options": {
        "jestConfig": "apps/portfolio-web/jest.config.ts",
        "passWithNoTests": true
      },
      "cache": true,
      "dependsOn": ["prebuild"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "inputs": ["default", "{workspaceRoot}/eslint.config.mjs"],
      "cache": true,
      "options": {
        "lintFilePatterns": ["apps/portfolio-web/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}