{
  "name": "@metashark/portfolio-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/portfolio-web/src",
  "projectType": "application",
  "targets": {
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/sovereign-prebuild.ts",
        "color": true
      },
      "outputs": [
        "{projectRoot}/src/dictionaries/*.json",
        "{workspaceRoot}/packages/cms/core/src/payload-types.ts"
      ],
      "cache": true
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{projectRoot}/.next"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "apps/portfolio-web"
      },
      "dependsOn": ["prebuild"]
    }
  }
}