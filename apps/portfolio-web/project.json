{
  "name": "@metashark/portfolio-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/portfolio-web/src",
  "projectType": "application",
  "tags": ["scope:metashark", "platform:web", "type:app"],
  "targets": {
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dlx tsx apps/portfolio-web/scripts/sovereign-prebuild.ts",
        "color": true
      },
      "outputs": ["{projectRoot}/src/dictionaries/*.json"]
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{workspaceRoot}/dist/apps/portfolio-web/.next"],
      "options": {
        "outputPath": "dist/apps/portfolio-web"
      },
      "dependsOn": ["prebuild"],
      "configurations": {
        "production": {
          "generateSourcemaps": false
        }
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "options": {
        "buildTarget": "@metashark/portfolio-web:build",
        "dev": true,
        "port": 4200
      },
      "dependsOn": ["prebuild"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/portfolio-web/tsconfig.json --noEmit"
      },
      "dependsOn": ["prebuild"]
    }
  }
}