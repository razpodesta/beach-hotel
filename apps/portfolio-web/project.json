{
  "name": "@metashark/portfolio-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/portfolio-web/src",
  "projectType": "application",
  "tags": [
    "platform:web",
    "scope:metashark",
    "type:app"
  ],
  "targets": {
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/prebuild-portfolio-web.ts",
        "color": true
      },
      "inputs": [
        "{projectRoot}/src/messages/**/*.json"
      ],
      "outputs": [
        "{projectRoot}/src/dictionaries/*.json"
      ],
      "cache": true,
      "description": "Protocolo MACS: Ensamblaje y validación soberana de diccionarios."
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/portfolio-web"
      },
      "configurations": {
        "development": {
          "outputPath": "dist/apps/portfolio-web/dev"
        },
        "production": {}
      },
      "dependsOn": [
        "prebuild"
      ],
      "cache": true
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "@metashark/portfolio-web:build",
        "dev": true,
        "port": 4200
      },
      "configurations": {
        "development": {
          "buildTarget": "@metashark/portfolio-web:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "@metashark/portfolio-web:build:production",
          "dev": false
        }
      },
      "dependsOn": [
        "prebuild"
      ]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/portfolio-web/tsconfig.json --noEmit",
        "forwardAllArgs": true
      },
      "cache": true,
      "dependsOn": [
        "prebuild"
      ],
      "description": "Verificación estática de tipos de élite sobre el código vivo."
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/apps/portfolio-web"
      ],
      "options": {
        "jestConfig": "apps/portfolio-web/jest.config.ts",
        "passWithNoTests": true
      },
      "cache": true
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.mjs"
      ],
      "cache": true,
      "options": {
        "lintFilePatterns": [
          "apps/portfolio-web/**/*.{ts,tsx,js,jsx}"
        ]
      }
    }
  }
}